// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Recipe {
  id    String @id @default(cuid())
  title String
  slug  String @unique

  ingredients RecipeIngredient[]
  steps       RecipeStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model Ingredient {
  id             String @id @default(cuid())
  name           String
  normalizedName String @unique

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Unit {
  id           String @id @default(cuid())
  name         String @unique
  abbreviation String

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  quantity Float?

  unitId String?
  unit   Unit? @relation(fields: [unitId], references: [id])

  preparation String?

  optional Boolean @default(false)

  displayOrder Int

  usages RecipeStepIngredientUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([ingredientId])
}

model RecipeStep {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  stepNumber Int

  markdown String

  ingredientUsages RecipeStepIngredientUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recipeId, stepNumber])
  @@index([recipeId])
}

model RecipeStepIngredientUsage {
  id String @id @default(cuid())

  recipeStepId String
  recipeStep   RecipeStep @relation(fields: [recipeStepId], references: [id], onDelete: Cascade)

  recipeIngredientId String
  recipeIngredient   RecipeIngredient @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  quantity Float

  displayOrder Int

  createdAt DateTime @default(now())

  @@index([recipeStepId])
  @@index([recipeIngredientId])
}
